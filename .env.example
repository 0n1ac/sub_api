# 서버 설정
HOST=127.0.0.1
PORT=8000

# CLI 응답 대기 시간(초)
TIMEOUT=60

# model이 생략됐을 때 사용할 백엔드: gemini, claude, codex
DEFAULT_BACKEND=gemini

# 백엔드별 세부 모델 기본값 (비워두면 각 CLI의 native default 사용)
# SUB_API_DEFAULT_MODEL_GEMINI=gemini-2.5-pro
# SUB_API_DEFAULT_MODEL_CLAUDE=sonnet
# SUB_API_DEFAULT_MODEL_CODEX=gpt-5
